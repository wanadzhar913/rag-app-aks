# ---- Application Settings ----
PROJECT_NAME=Malaysian Road Transport Law Agent (Backend)
DESCRIPTION=Malaysian Road Transport Law Agent is a tool that helps users to find the law related to road transport in Malaysia.
VERSION=1.0.0
ENVIRONMENT=local
DEBUG=true

# ---- Backend API Settings ----
API_V1_STR=/api/v1

# ---- Postgres ----
POSTGRES_USER=rag_app
POSTGRES_PASSWORD=rag_app_pass
POSTGRES_DB=rag_app_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ---- S3 / MinIO ----
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=ap-southeast-5

# ---- LLM Settings ----
OPENAI_API_KEY=""
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_MODEL=gpt-5-mini
DEFAULT_LLM_TEMPERATURE=0.1
MAX_TOKENS=32768

# ---- Ingestion ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=20

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# ---- Redis Cache Settings ----
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20
CACHE_TTL_SECONDS=60

# ---- Long term memory Configuration ----
LONG_TERM_MEMORY_MODEL=gpt-4o-mini
LONG_TERM_MEMORY_EMBEDDER_MODEL=text-embedding-3-small
LONG_TERM_MEMORY_COLLECTION_NAME=longterm_memory

# ---- Other ----
HF_TOKEN=""