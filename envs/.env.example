# ---- Environment ----
ENVIRONMENT=local
DEBUG=true

# ---- Postgres ----
POSTGRES_USER=rag_app
POSTGRES_PASSWORD=rag_app_pass
POSTGRES_DB=rag_app_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ---- S3 / MinIO ----
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=ap-southeast-5

# ---- OpenAI ----
OPENAI_API_KEY=""
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Backend ----
DEBUG=true
PROJECT_NAME=RAG App
DEFAULT_LLM_MODEL=gpt-5-mini
MAX_TOKENS=16384

# ---- Ingestion ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=20
